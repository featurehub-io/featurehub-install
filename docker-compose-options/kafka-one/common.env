#general
monitor.port=8701
nats.enabled=false
dacha1.enabled=false
dacha2.enabled=true
# inside party server, don't run NATS
dont-run-nats-server=true
cloudevents.kafka.enabled=true
cloudevents.kafka.bootstrap.servers=kafka:9092
cloudevents.kafka.consumer.auto-topic-creation=true
cloudevents.kafka.compress-events=false

sdk.feature.properties=appName={{{feature.parentApplication.name}}},portfolio={{{feature.parentApplication.portfolio.name}}},category={{{metadata.category}}}

#ensure monitoring ports are off so we have only 1 external port, ECS generally does not like > 1 port, nor does knative
monitor.port=8701

# edge
edge.sse.drop-after-seconds=60
update.pool-size=30
listen.pool-size=30

#mr
db.url=jdbc:postgresql://db:5432/featurehub
db.username=featurehub
db.password=featurehub
db.connections=10
run.nginx=true
jersey.cors.headers=X-Requested-With,Authorization,Content-type,Accept-Version,Content-MD5,CSRF-Token,x-ijt,cache-control,Baggage
jersey.logging.exclude-entirely-uris=/health/liveness,/health/readiness,/metrics
portfolio.admin.group.suffix=Administrators
