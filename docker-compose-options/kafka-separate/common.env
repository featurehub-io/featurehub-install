nats.enabled=false
dacha1.enabled=false
dacha2.enabled=true

#kafka config
cloudevents.kafka.enabled=true
cloudevents.kafka.bootstrap.servers=kafka:9092
cloudevents.kafka.consumer.auto-topic-creation=true
cloudevents.kafka.compress-events=false

sdk.feature.properties=appName={{{feature.parentApplication.name}}},portfolio={{{feature.parentApplication.portfolio.name}}},category={{{metadata.category}}}

#ensure monitoring ports are off so we have only 1 external port, ECS generally does not like > 1 port, nor does knative
monitor.port=0
